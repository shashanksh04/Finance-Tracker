{
  "expo": {
    "name": "Finance Tracker",
    "slug": "finance-tracker-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "financetracker",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.financetracker.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to protect your financial data",
        "NSCameraUsageDescription": "Use camera to scan receipts and bills",
        "NSPhotoLibraryUsageDescription": "Access photos for receipt scanning"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.financetracker.mobile",
      "permissions": [
        "USE_BIOMETRIC",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-local-authentication",
      "expo-notifications",
      "expo-background-fetch"
    ]
  }
}
